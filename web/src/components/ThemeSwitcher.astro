<div class="theme-switcher" role="group" aria-label="Prepínač režimu zobrazenia">
  <button type="button" data-theme-value="default" aria-pressed="true" title="Deň">
    <span class="theme-switcher-icon" aria-hidden="true">☀</span>
    <span class="sr-only">Deň</span>
  </button>
  <button type="button" data-theme-value="dark" aria-pressed="false" title="Noc">
    <span class="theme-switcher-icon" aria-hidden="true">☾</span>
    <span class="sr-only">Noc</span>
  </button>
</div>
