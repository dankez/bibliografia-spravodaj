---
import '../styles/global.css';
import packageInfo from '../../package.json';

interface Props {
	title?: string;
}

const { title = "Spravodaj SSS — Bibliografický portál" } = Astro.props;
const assetBase = import.meta.env.BASE_URL;
const releaseDate = import.meta.env.PUBLIC_RELEASE_DATE || new Date().toISOString().slice(0, 10).replaceAll('-', '');
const releaseSha = String(import.meta.env.PUBLIC_RELEASE_SHA || import.meta.env.CF_PAGES_COMMIT_SHA || 'local').slice(0, 7);
const releaseLabel = `v${packageInfo.version}-beta.${releaseDate}+${releaseSha}`;
---

<!doctype html>
<html lang="sk">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/brand/bibliografia-logo.png" />
		<link rel="apple-touch-icon" href="/brand/bibliografia-logo.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&display=swap" rel="stylesheet" />
		<script is:inline>
			(() => {
				try {
					const mobile = window.matchMedia('(max-width: 1023px)');
					const stored = localStorage.getItem('sss-theme');
					const safeTheme = ['default', 'dark'].includes(stored) ? stored : 'default';
					const applyTheme = () => {
						document.documentElement.dataset.theme = mobile.matches && safeTheme === 'dark' ? 'default' : safeTheme;
					};
					applyTheme();
					mobile.addEventListener?.('change', applyTheme);
				} catch {
					document.documentElement.dataset.theme = 'default';
				}
			})();
		</script>
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content="Online bibliografický a informačný portál časopisu Spravodaj Slovenskej speleologickej spoločnosti. Prehľad článkov, speleologických výskumov a jaskyniarskych príspevkov." />
		
		<!-- Dynamic Head Slot for Google Scholar & JSON-LD -->
		<slot name="head" />
	</head>
	<body class="bg-belly-gainsboro text-belly-black font-sans antialiased min-h-screen">
		<slot />
		<footer class="site-author-signature" aria-label="Autor projektu">
			<span>Autor: <a href="https://github.com/dankez" rel="author noopener" target="_blank">DankeZ</a></span>
			<span class="site-release">release: {releaseLabel}</span>
		</footer>
		<script src={`${assetBase}theme-switcher.js`} defer></script>
	</body>
</html>
