---
import Layout from '../../layouts/Layout.astro';
import ThemeSwitcher from '../../components/ThemeSwitcher.astro';

const endpoint = import.meta.env.PUBLIC_ADMIN_ERRATA_ENDPOINT || '/api/admin/errata';
const loginEndpoint = import.meta.env.PUBLIC_ADMIN_LOGIN_ENDPOINT || '/api/admin/login';
const logoutEndpoint = import.meta.env.PUBLIC_ADMIN_LOGOUT_ENDPOINT || '/api/admin/logout';
const sessionEndpoint = import.meta.env.PUBLIC_ADMIN_SESSION_ENDPOINT || '/api/admin/session';
---

<Layout title="Admin opravy — Digitálna bibliografia SSS">
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <div class="portal-page min-h-screen text-belly-black">
    <header class="portal-header border-b border-belly-darkgray">
      <div class="h-2 bg-belly-firebrick"></div>
      <div class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-5 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-belly-peru">Redakčný režim</p>
          <h1 class="font-display text-3xl font-extrabold leading-tight text-belly-firebrick">Admin opravy</h1>
          <p class="mt-2 max-w-3xl text-sm leading-relaxed text-belly-dimgray">
            Kontrola komunitných errata z GitHub issues. Štruktúrované opravy článkov sa schvaľujú spustením GitHub Actions workflow, ktorý zapíše dáta, zavrie issue a spustí nový Cloudflare deploy.
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <ThemeSwitcher />
          <a href="/" class="bibliography-link-button">Hlavný archív</a>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-5 py-6">
      <section class="portal-toolbar mb-5 border border-belly-darkgray p-4">
        <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
          <div class="admin-access-panel">
            <p class="bibliography-section-title">Admin login</p>
            <p class="mt-2 text-sm leading-relaxed text-belly-dimgray">
              Admin časť je chránená heslom a serverovou HttpOnly session cookie. Heslo sa overuje iba voči hashu uloženému v Cloudflare env.
            </p>
            <p class="mt-2 text-xs font-bold uppercase tracking-wider text-belly-dimgray">
              Stav: <span id="admin-user-email" class="text-belly-firebrick">neprihlásený</span>
            </p>
          </div>
          <form id="admin-login-form" class="admin-login-form" autocomplete="on">
            <label class="report-field">
              <span>Heslo</span>
              <input id="admin-password" type="password" autocomplete="current-password" placeholder="Admin heslo" required />
            </label>
            <button id="admin-login-btn" class="bibliography-button-primary px-5 py-2.5 font-bold" type="submit">Prihlásiť</button>
          </form>
          <div id="admin-session-actions" class="flex flex-wrap gap-2" hidden>
            <button id="load-errata-btn" class="bibliography-button-primary px-5 py-2.5 font-bold" type="button">Načítať opravy</button>
            <button id="admin-logout-btn" class="bibliography-button-secondary px-5 py-2.5 font-bold" type="button">Odhlásiť</button>
          </div>
        </div>
        <p id="admin-status" class="mt-3 text-sm text-belly-dimgray" role="status" aria-live="polite"></p>
      </section>

      <section class="admin-errata-layout">
        <aside class="admin-errata-list border border-belly-darkgray" aria-label="Zoznam otvorených opráv">
          <div class="admin-errata-list-header">
            <h2 class="font-display text-xl font-bold text-belly-black-brown">Otvorené hlásenia</h2>
            <span id="admin-errata-count" class="article-result-badge">0</span>
          </div>
          <div id="admin-errata-list" class="admin-errata-items">
            <p class="p-4 text-sm text-belly-dimgray">Prihlás sa admin heslom a načítaj otvorené issues.</p>
          </div>
        </aside>

        <section class="admin-errata-detail border border-belly-darkgray" aria-label="Detail opravy">
          <div id="admin-errata-detail-empty" class="admin-errata-empty">
            Vyber hlásenie zo zoznamu.
          </div>
          <article id="admin-errata-detail" hidden>
            <div class="article-result-meta">
              <span id="detail-issue-number"></span>
              <span class="separator">/</span>
              <span id="detail-issue-type"></span>
              <span class="separator">/</span>
              <span id="detail-issue-date"></span>
            </div>
            <h2 id="detail-issue-title" class="mt-2 font-display text-2xl font-bold leading-tight text-belly-black-brown"></h2>
            <p id="detail-issue-author" class="mt-2 text-sm font-semibold text-belly-dimgray-earth"></p>
            <div class="mt-4 flex flex-wrap gap-2">
              <a id="detail-issue-link" href="#" target="_blank" rel="noreferrer" class="bibliography-link-button">Otvoriť issue</a>
              <button id="approve-issue-btn" class="bibliography-button-primary px-5 py-2.5 font-bold" type="button">Schváliť a zapísať</button>
            </div>

            <section id="detail-article-edit" class="mt-5">
              <h3 class="bibliography-section-title">Porovnanie zmien</h3>
              <div class="admin-diff-table-wrap mt-3">
                <table class="admin-diff-table">
                  <thead>
                    <tr>
                      <th>Pole</th>
                      <th>Pôvodné</th>
                      <th>Navrhované</th>
                    </tr>
                  </thead>
                  <tbody id="admin-diff-body"></tbody>
                </table>
              </div>
              <div class="admin-approval-footer">
                <p>
                  Schválenie spustí GitHub Actions workflow. Ten zapíše opravu do dát, zavrie issue a Cloudflare Pages automaticky spustí nový deploy.
                </p>
                <button id="approve-issue-bottom-btn" class="bibliography-button-primary px-5 py-2.5 font-bold" type="button">
                  Schváliť opravu a zapísať do webu
                </button>
              </div>
            </section>

            <section id="detail-manual" class="article-abstract-box mt-5 p-4" hidden>
              Toto hlásenie nemá štruktúrovaný JSON diff. Otvor issue na GitHube a vybav ho ručne.
            </section>

            <section id="detail-result" class="admin-approve-result mt-5" hidden>
              <h3 class="bibliography-section-title">Výsledok schválenia</h3>
              <p id="detail-result-text" class="mt-2 text-sm text-belly-dimgray"></p>
              <a id="detail-pr-link" href="#" target="_blank" rel="noreferrer" class="bibliography-link-button mt-3">Otvoriť workflow</a>
            </section>
          </article>
        </section>
      </section>
    </main>
  </div>

  <script define:vars={{ endpoint, loginEndpoint, logoutEndpoint, sessionEndpoint }}>
    const loginForm = document.getElementById('admin-login-form');
    const passwordInput = document.getElementById('admin-password');
    const loginButton = document.getElementById('admin-login-btn');
    const sessionActions = document.getElementById('admin-session-actions');
    const logoutButton = document.getElementById('admin-logout-btn');
    const loadButton = document.getElementById('load-errata-btn');
    const status = document.getElementById('admin-status');
    const userEmail = document.getElementById('admin-user-email');
    const countBadge = document.getElementById('admin-errata-count');
    const list = document.getElementById('admin-errata-list');
    const emptyDetail = document.getElementById('admin-errata-detail-empty');
    const detail = document.getElementById('admin-errata-detail');
    const approveButton = document.getElementById('approve-issue-btn');
    const approveBottomButton = document.getElementById('approve-issue-bottom-btn');
    const diffBody = document.getElementById('admin-diff-body');
    const articleEditSection = document.getElementById('detail-article-edit');
    const manualSection = document.getElementById('detail-manual');
    const resultSection = document.getElementById('detail-result');
    const resultText = document.getElementById('detail-result-text');
    const prLink = document.getElementById('detail-pr-link');
    let issues = [];
    let selectedIssue = null;
    let isLoggedIn = false;

    function setStatus(message, isError = false) {
      status.textContent = message;
      status.classList.toggle('text-belly-firebrick', isError);
      status.classList.toggle('text-belly-dimgray', !isError);
    }

    function textNode(value) {
      return document.createTextNode(String(value ?? ''));
    }

    function formatValue(value) {
      if (Array.isArray(value)) return value.length ? value.join('\n') : '—';
      if (value === true) return 'áno';
      if (value === false) return 'nie';
      if (value === null || value === undefined || value === '') return '—';
      if (typeof value === 'object') return JSON.stringify(value, null, 2);
      return String(value);
    }

    function formatDate(value) {
      if (!value) return 'neuvedené';
      try {
        return new Intl.DateTimeFormat('sk-SK', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(value));
      } catch {
        return value;
      }
    }

    function appendText(parent, tag, className, value) {
      const element = document.createElement(tag);
      if (className) element.className = className;
      element.append(textNode(value));
      parent.append(element);
      return element;
    }

    function adminHeaders() {
      return {
        Accept: 'application/json',
        'Content-Type': 'application/json',
      };
    }

    async function readJsonResponse(response) {
      const text = await response.text();
      if (!text) return {};
      try {
        return JSON.parse(text);
      } catch {
        return { error: `Server vrátil nečitateľnú odpoveď (HTTP ${response.status}). ${text.slice(0, 300)}` };
      }
    }

    function setApproveButtonsDisabled(disabled) {
      approveButton.disabled = disabled;
      approveBottomButton.disabled = disabled;
    }

    function setApproveButtonsVisible(visible) {
      approveButton.hidden = !visible;
      approveBottomButton.hidden = !visible;
      setApproveButtonsDisabled(!visible);
    }

    function isStructuredIssue(issue) {
      return ['article_edit', 'fulltext_review'].includes(issue?.type);
    }

    function issueTypeLabel(type) {
      if (type === 'article_edit') return 'edit článku';
      if (type === 'fulltext_review') return 'kontrola fulltextu';
      return 'ručné hlásenie';
    }

    function setLoggedIn(user) {
      isLoggedIn = true;
      loginForm.hidden = true;
      sessionActions.hidden = false;
      userEmail.textContent = user?.email || 'admin';
      passwordInput.value = '';
    }

    function setLoggedOut(message = 'Neprihlásený.') {
      isLoggedIn = false;
      loginForm.hidden = false;
      sessionActions.hidden = true;
      userEmail.textContent = 'neprihlásený';
      issues = [];
      selectedIssue = null;
      renderIssueList();
      emptyDetail.hidden = false;
      detail.hidden = true;
      setStatus(message);
    }

    async function checkSession() {
      try {
        const response = await fetch(sessionEndpoint, { headers: adminHeaders(), credentials: 'same-origin' });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || !payload.ok) {
          setLoggedOut('Zadaj admin heslo.');
          return;
        }
        setLoggedIn(payload.user);
        setStatus('Admin relácia je aktívna.');
      } catch {
        setLoggedOut('Zadaj admin heslo.');
      }
    }

    async function loginAdmin(event) {
      event.preventDefault();
      const password = passwordInput.value;
      if (!password) {
        setStatus('Zadaj admin heslo.', true);
        return;
      }
      loginButton.disabled = true;
      setStatus('Prihlasujem...');
      try {
        const response = await fetch(loginEndpoint, {
          method: 'POST',
          headers: adminHeaders(),
          credentials: 'same-origin',
          body: JSON.stringify({ password }),
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || !payload.ok) throw new Error(payload.error || 'Prihlásenie zlyhalo.');
        setLoggedIn(payload.user);
        setStatus('Prihlásenie prebehlo úspešne.');
        await loadIssues();
      } catch (error) {
        setStatus(error.message || 'Prihlásenie zlyhalo.', true);
      } finally {
        loginButton.disabled = false;
      }
    }

    async function logoutAdmin() {
      logoutButton.disabled = true;
      try {
        await fetch(logoutEndpoint, {
          method: 'POST',
          headers: adminHeaders(),
          credentials: 'same-origin',
          body: JSON.stringify({}),
        });
      } finally {
        logoutButton.disabled = false;
        setLoggedOut('Odhlásené.');
      }
    }

    function renderIssueList() {
      list.replaceChildren();
      countBadge.textContent = String(issues.length);
      if (!issues.length) {
        appendText(list, 'p', 'p-4 text-sm text-belly-dimgray', 'Nie sú otvorené errata issues.');
        return;
      }
      const fragment = document.createDocumentFragment();
      issues.forEach((issue) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'admin-errata-item';
        button.dataset.issueNumber = String(issue.number);
        appendText(button, 'span', 'admin-errata-item-kicker', `#${issue.number} · ${issueTypeLabel(issue.type)}`);
        appendText(button, 'strong', '', issue.title);
        appendText(button, 'span', 'admin-errata-item-meta', `${formatDate(issue.created_at)} · ${issue.author || 'neznámy autor'}`);
        button.addEventListener('click', () => selectIssue(issue.number));
        fragment.append(button);
      });
      list.append(fragment);
    }

    function renderDiff(issue) {
      diffBody.replaceChildren();
      const patch = issue.patch;
      if (issue.type === 'fulltext_review') {
        [
          ['Rozhodnutie', '—', patch?.decision || '—'],
          ['Incident', '—', patch?.decision_key || '—'],
          ['Článok', patch?.article_id || '—', patch?.article_title || '—'],
          ['Problém', patch?.primary_issue || '—', patch?.primary_label || '—'],
          ['Strany', '—', patch?.pages || '—'],
          ['PDF', '—', patch?.pdf_url || '—'],
          ['Audit', '—', patch?.source_generated_at || '—'],
        ].forEach(([field, originalValue, proposedValue]) => {
          const row = document.createElement('tr');
          appendText(row, 'th', '', field);
          const original = document.createElement('td');
          const originalPre = document.createElement('pre');
          originalPre.append(textNode(formatValue(originalValue)));
          original.append(originalPre);
          const proposed = document.createElement('td');
          const proposedPre = document.createElement('pre');
          proposedPre.append(textNode(formatValue(proposedValue)));
          proposed.append(proposedPre);
          row.append(original, proposed);
          diffBody.append(row);
        });
        return;
      }
      (patch?.changed_fields || []).forEach((field) => {
        const row = document.createElement('tr');
        appendText(row, 'th', '', field);
        const original = document.createElement('td');
        const originalPre = document.createElement('pre');
        originalPre.append(textNode(formatValue(patch.original?.[field])));
        original.append(originalPre);
        const proposed = document.createElement('td');
        const proposedPre = document.createElement('pre');
        proposedPre.append(textNode(formatValue(patch.proposed?.[field])));
        proposed.append(proposedPre);
        row.append(original, proposed);
        diffBody.append(row);
      });
    }

    function selectIssue(issueNumber) {
      selectedIssue = issues.find((issue) => Number(issue.number) === Number(issueNumber));
      if (!selectedIssue) return;
      list.querySelectorAll('.admin-errata-item').forEach((item) => {
        item.classList.toggle('is-selected', item.dataset.issueNumber === String(issueNumber));
      });
      emptyDetail.hidden = true;
      detail.hidden = false;
      resultSection.hidden = true;
      document.getElementById('detail-issue-number').textContent = `Issue #${selectedIssue.number}`;
      document.getElementById('detail-issue-type').textContent = issueTypeLabel(selectedIssue.type);
      document.getElementById('detail-issue-date').textContent = formatDate(selectedIssue.created_at);
      document.getElementById('detail-issue-title').textContent = selectedIssue.title;
      document.getElementById('detail-issue-author').textContent = selectedIssue.author ? `Autor hlásenia: ${selectedIssue.author}` : 'Autor hlásenia: neuvedený';
      const issueLink = document.getElementById('detail-issue-link');
      issueLink.href = selectedIssue.url || '#';
      articleEditSection.hidden = !isStructuredIssue(selectedIssue);
      manualSection.hidden = isStructuredIssue(selectedIssue);
      setApproveButtonsVisible(isStructuredIssue(selectedIssue));
      if (isStructuredIssue(selectedIssue)) renderDiff(selectedIssue);
    }

    async function loadIssues() {
      if (!isLoggedIn) {
        setStatus('Najprv sa prihlás admin heslom.', true);
        return;
      }
      loadButton.disabled = true;
      setStatus('Načítavam GitHub issues...');
      try {
        const response = await fetch(endpoint, { headers: adminHeaders(), credentials: 'same-origin' });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || !payload.ok) throw new Error(payload.error || 'Issues sa nepodarilo načítať.');
        userEmail.textContent = payload.user?.email || 'admin';
        issues = Array.isArray(payload.issues) ? payload.issues : [];
        renderIssueList();
        emptyDetail.hidden = false;
        detail.hidden = true;
        setStatus(`Načítané: ${issues.length} otvorených hlásení.`);
      } catch (error) {
        setStatus(error.message || 'Issues sa nepodarilo načítať.', true);
      } finally {
        loadButton.disabled = false;
      }
    }

    async function approveSelectedIssue() {
      if (!isStructuredIssue(selectedIssue)) return;
      setApproveButtonsDisabled(true);
      setStatus(`Spúšťam schvaľovací workflow pre issue #${selectedIssue.number}...`);
      resultSection.hidden = true;
      try {
        const response = await fetch(endpoint, {
          method: 'POST',
          headers: adminHeaders(),
          credentials: 'same-origin',
          body: JSON.stringify({ issueNumber: selectedIssue.number }),
        });
        const payload = await readJsonResponse(response);
        if (!response.ok || !payload.ok) throw new Error(payload.error || `Schválenie zlyhalo (HTTP ${response.status}).`);
        const approval = payload.approval || {};
        resultText.textContent = `Schválenie bolo odoslané do GitHub Actions workflow ${approval.workflow || 'approve-errata.yml'} pre vetvu ${approval.branch || 'main'}. Po dokončení workflow vznikne commit, issue sa zavrie a Cloudflare Pages spustí nový deploy.`;
        prLink.href = approval.workflowUrl || '#';
        resultSection.hidden = false;
        setStatus(`Schvaľovací workflow bol spustený: ${approval.workflowUrl || ''}`);
        selectedIssue = null;
        setApproveButtonsVisible(false);
      } catch (error) {
        setStatus(error.message || 'Schválenie zlyhalo.', true);
      } finally {
        if (isStructuredIssue(selectedIssue)) setApproveButtonsDisabled(false);
      }
    }

    loginForm.addEventListener('submit', loginAdmin);
    loadButton.addEventListener('click', loadIssues);
    logoutButton.addEventListener('click', logoutAdmin);
    approveButton.addEventListener('click', approveSelectedIssue);
    approveBottomButton.addEventListener('click', approveSelectedIssue);
    checkSession();
  </script>
</Layout>
