---
import Layout from '../layouts/Layout.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import articlesData from '../data/articles.json';

const uiArticlesData = articlesData;
const DEFAULT_JOURNAL_ID = 'spravodaj_sss';
const DEFAULT_JOURNAL_TITLE = 'Spravodaj Slovenskej speleologickej spoločnosti';
const DEFAULT_JOURNAL_SHORT_TITLE = 'Spravodaj SSS';
const articleJournalId = (article) => article.journal_id || DEFAULT_JOURNAL_ID;
const articleJournalLabel = (article) => article.journal_short_title || article.journal_title || DEFAULT_JOURNAL_SHORT_TITLE;
const articleHasMapPlan = (article) =>
  article.has_map_plan === true || (article.map_plan_pages || []).length > 0;

const totalArticles = uiArticlesData.length;
const startYear = Math.min(...uiArticlesData.map((article) => article.year));
const endYear = Math.max(...uiArticlesData.map((article) => article.year), new Date().getFullYear());
const archiveHomeHref = `/?year=${startYear}-${endYear}`;
const articlesWithMaps = uiArticlesData.filter(articleHasMapPlan).length;
const totalUniqueAuthors = new Set(
  uiArticlesData.flatMap((article) => article.authors || []).filter((author) => !['Anonymus', 'Redakcia'].includes(author))
).size;
const journalOptions = Array.from(
  uiArticlesData.reduce((items, article) => {
    const id = articleJournalId(article);
    if (!items.has(id)) {
      items.set(id, {
        id,
        label: articleJournalLabel(article),
        title: article.journal_title || DEFAULT_JOURNAL_TITLE,
      });
    }
    return items;
  }, new Map()).values()
).sort((a, b) => {
  const order = new Map([
    ['spravodaj_sss', 0],
    ['aragonit', 1],
    ['slovensky_kras', 2],
  ]);
  return (order.get(a.id) ?? 99) - (order.get(b.id) ?? 99) || a.label.localeCompare(b.label, 'sk');
});

const exportScopes = [
  { label: 'Všetko spolu', dankoBase: 'bibliografia_vsetko_danko', sqlite: 'bibliografia_vsetko.sqlite' },
  { label: 'Spravodaj SSS', dankoBase: 'bibliografia_spravodaj_sss_danko', sqlite: 'bibliografia_spravodaj_sss.sqlite' },
  { label: 'Aragonit', dankoBase: 'bibliografia_aragonit_danko', sqlite: 'bibliografia_aragonit.sqlite' },
  { label: 'Slovenský kras', dankoBase: 'bibliografia_slovensky_kras_danko', sqlite: 'bibliografia_slovensky_kras.sqlite' },
];
const bibliographyExportMenus = [
  {
    label: 'HTML',
    download: false,
    items: exportScopes.map((scope) => ({ label: scope.label, href: `/exports/${scope.dankoBase}.html` })),
  },
  {
    label: 'MD',
    download: true,
    items: exportScopes.map((scope) => ({ label: scope.label, href: `/exports/${scope.dankoBase}.md` })),
  },
  {
    label: 'PDF',
    download: true,
    items: exportScopes.map((scope) => ({ label: scope.label, href: `/exports/${scope.dankoBase}.pdf` })),
  },
  {
    label: 'SQL',
    download: true,
    items: exportScopes.map((scope) => ({ label: scope.label, href: `/exports/${scope.sqlite}` })),
  },
  {
    label: 'TLAČ',
    icon: 'print',
    download: false,
    items: exportScopes.map((scope) => ({ label: scope.label, href: `/exports/${scope.dankoBase}_tlac.html` })),
  },
];
---

<Layout title="Spravodaj SSS — Slovenská speleologická bibliografia">
  <div class="bibliography-app flex min-h-screen flex-col text-belly-black">
    <header class="bibliography-header border-b border-belly-darkgray shadow-sm">
      <div class="h-2 bg-belly-firebrick"></div>
      <div class="bibliography-header-inner mx-auto flex max-w-none flex-col gap-4 px-3 py-3 lg:flex-row lg:items-center lg:justify-between lg:px-3">
        <div class="bibliography-header-top flex items-start justify-between gap-3">
          <a href={archiveHomeHref} class="bibliography-brand" aria-label="Digitálna bibliografia Slovenská speleologická spoločnosť">
            <img
              src="/brand/bibliografia-banner-ui-sm.webp"
              srcset="/brand/bibliografia-banner-ui-sm.webp 320w, /brand/bibliografia-banner-ui-md.webp 480w, /brand/bibliografia-banner-ui.webp 640w"
              sizes="(min-width: 1024px) min(34vw, 560px), 0px"
              alt="Digitálna bibliografia Slovenská speleologická spoločnosť"
              class="bibliography-brand-banner"
              width="320"
              height="88"
              fetchpriority="high"
            />
						<img
							src="/brand/bibliografia-logo-mobile.webp"
							srcset="/brand/bibliografia-logo-mobile.webp 192w, /brand/bibliografia-logo-mobile-256.webp 256w"
							sizes="(max-width: 1023px) clamp(92px, 26vw, 124px), 0px"
							alt=""
							class="bibliography-brand-logo"
              width="192"
              height="124"
              aria-hidden="true"
              fetchpriority="high"
            />
            <h1 class="sr-only">Digitálna bibliografia Slovenskej speleologickej spoločnosti</h1>
            <p class="sr-only">Kompletný archív ročníkov {startYear}-{endYear}, mapy a plány sú zoradené prvé</p>
          </a>
          <div class="bibliography-mobile-actions" aria-label="Mobilné nástroje">
            <button id="mobile-search-toggle" class="bibliography-icon-button" type="button" aria-label="Hľadať v bibliografii" aria-controls="mobile-search-overlay">
              <span aria-hidden="true">⌕</span>
            </button>
            <button id="mobile-menu-toggle" class="bibliography-icon-button" type="button" aria-label="Otvoriť menu" aria-controls="mobile-menu-panel" aria-expanded="false">
              <span aria-hidden="true">☰</span>
            </button>
          </div>
        </div>
        <div class="flex flex-col gap-3 lg:items-end">
          <div class="bibliography-desktop-actions flex items-center gap-2 lg:justify-end">
            <div class="mobile-theme-hidden">
              <ThemeSwitcher />
            </div>
            <a href="/jaskyne/" class="bibliography-link-button bibliography-link-button-primary">
              Register jaskýň
            </a>
            <div class="bibliography-export-links" aria-label="Danko exporty bibliografie">
              {bibliographyExportMenus.map((exportMenu) => (
                <details class="bibliography-export-menu">
                  <summary
                    class="bibliography-link-button bibliography-export-trigger"
                  >
                    {exportMenu.icon === 'print' ? (
                      <svg class="bibliography-export-printer-icon" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M6 9V3h12v6" />
                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                        <path d="M6 14h12v7H6z" />
                        <path d="M18 13h.01" />
                      </svg>
                    ) : (
                      <span class="bibliography-export-download-icon" aria-hidden="true">↓</span>
                    )}
                    <span>{exportMenu.label}</span>
                    <span class="bibliography-export-chevron" aria-hidden="true">⌄</span>
                  </summary>
                  <div class="bibliography-export-menu-panel" role="menu" aria-label={`Export ${exportMenu.label}`}>
                    {exportMenu.items.map((item) => (
                      <a href={item.href} role="menuitem" download={exportMenu.download ? true : undefined}>
                        {item.label}
                      </a>
                    ))}
                  </div>
                </details>
              ))}
            </div>
          </div>
          <div id="mobile-menu-panel" class="bibliography-mobile-menu" hidden>
            <a href="/jaskyne/" class="bibliography-link-button bibliography-link-button-primary" data-mobile-menu-link="jaskyne">
              Register jaskýň
            </a>
            <div class="bibliography-mobile-menu-section" data-mobile-menu-link="exports" aria-label="Exporty bibliografie">
              {bibliographyExportMenus.map((exportMenu) => (
                <details class="bibliography-export-menu bibliography-export-menu-mobile">
                  <summary
                    class="bibliography-link-button bibliography-export-trigger"
                  >
                    {exportMenu.icon === 'print' ? (
                      <svg class="bibliography-export-printer-icon" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M6 9V3h12v6" />
                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                        <path d="M6 14h12v7H6z" />
                        <path d="M18 13h.01" />
                      </svg>
                    ) : (
                      <span class="bibliography-export-download-icon" aria-hidden="true">↓</span>
                    )}
                    <span>{exportMenu.label}</span>
                    <span class="bibliography-export-chevron" aria-hidden="true">⌄</span>
                  </summary>
                  <div class="bibliography-export-menu-panel" role="menu" aria-label={`Export ${exportMenu.label}`}>
                    {exportMenu.items.map((item) => (
                      <a href={item.href} role="menuitem" download={exportMenu.download ? true : undefined}>
                        {item.label}
                      </a>
                    ))}
                  </div>
                </details>
              ))}
            </div>
          </div>
          <dl class="grid grid-cols-2 gap-3 text-xs font-mono sm:grid-cols-4">
            <div class="border-l border-belly-darkgray pl-3"><dt class="text-belly-dimgray">Článkov</dt><dd id="stat-total" class="font-bold text-belly-firebrick">{totalArticles}</dd></div>
            <div class="border-l border-belly-darkgray pl-3"><dt class="text-belly-dimgray">Roky</dt><dd class="font-bold text-belly-firebrick">{startYear}-{endYear}</dd></div>
            <div class="border-l border-belly-darkgray pl-3"><dt class="text-belly-dimgray">Mapy/plány</dt><dd id="stat-maps" class="font-bold text-belly-peru">{articlesWithMaps}</dd></div>
            <div class="border-l border-belly-darkgray pl-3"><dt class="text-belly-dimgray">Autori</dt><dd class="font-bold text-belly-firebrick">{totalUniqueAuthors}</dd></div>
          </dl>
        </div>
      </div>
      <div id="mobile-search-overlay" class="mobile-search-overlay" aria-hidden="true" hidden>
        <div class="mobile-search-panel" role="dialog" aria-modal="true" aria-labelledby="mobile-search-title">
          <div class="mobile-search-header">
            <h2 id="mobile-search-title" class="sr-only">Hľadať v bibliografii</h2>
            <label class="sr-only" for="mobile-search-input">Hľadať</label>
            <input id="mobile-search-input" class="bibliography-search mobile-search-input" type="search" placeholder="Hľadať autora, jaskyňu, tému, rok..." autocomplete="off" />
            <button id="mobile-search-close" class="bibliography-icon-button" type="button" aria-label="Zatvoriť hľadanie">
              <span aria-hidden="true">×</span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <main class="bibliography-main mx-auto grid min-h-0 w-full flex-1 max-w-none grid-cols-1 overflow-hidden border-x border-belly-darkgray lg:grid-cols-[minmax(460px,42%)_minmax(0,58%)] 2xl:grid-cols-[minmax(640px,40%)_minmax(0,60%)]">
      <section class="bibliography-pane flex min-h-0 flex-col border-r border-belly-darkgray">
        <div class="bibliography-filterbar space-y-3 border-b border-belly-darkgray p-4">
          <div class="desktop-search-field">
            <label class="sr-only" for="search-input">Hľadať</label>
            <input id="search-input" class="bibliography-search w-full border border-belly-gray px-3 py-2 text-sm shadow-inner outline-none focus:border-belly-firebrick focus:ring-1 focus:ring-belly-firebrick" placeholder="Hľadať autora, jaskyňu, tému, rok..." />
          </div>

          <div class="grid grid-cols-2 gap-2">
            <div class="bibliography-control col-span-2 border border-belly-darkgray p-2">
              <div class="mb-1 flex justify-between text-[11px] font-mono text-belly-dimgray">
                <span>Roky: <strong id="year-range-label" class="text-belly-firebrick">{startYear} - {endYear}</strong></span>
                <button id="reset-years-btn" class="font-bold hover:text-belly-firebrick">Reset</button>
              </div>
              <div id="year-range-control" class="year-range-control" style="--range-start: 0%; --range-end: 100%;">
                <label class="sr-only" for="year-min">Najskorší rok</label>
                <input
                  id="year-min"
                  type="range"
                  min={startYear}
                  max={endYear}
                  value={startYear}
                  class="year-range-input year-range-input-min"
                  aria-label="Najskorší rok"
                />
                <label class="sr-only" for="year-max">Najneskorší rok</label>
                <input
                  id="year-max"
                  type="range"
                  min={startYear}
                  max={endYear}
                  value={endYear}
                  class="year-range-input year-range-input-max"
                  aria-label="Najneskorší rok"
                />
                <div class="year-range-scale" aria-hidden="true">
                  <span>{startYear}</span>
                  <span>{endYear}</span>
                </div>
              </div>
            </div>

            <div class="bibliography-control bibliography-journal-control border border-belly-gray p-2" aria-label="Filter časopisu">
              <details id="journal-filter-menu" class="bibliography-export-menu bibliography-journal-menu">
                <summary class="bibliography-link-button bibliography-export-trigger bibliography-journal-trigger">
                  <span class="bibliography-journal-kicker">Časopis</span>
                  <span id="journal-filter-current" class="bibliography-journal-current">Všetky</span>
                  <span class="bibliography-export-chevron" aria-hidden="true">⌄</span>
                </summary>
                <div class="bibliography-export-menu-panel bibliography-journal-menu-panel" role="menu" aria-label="Filter časopisu">
                  <button type="button" role="menuitemradio" aria-checked="true" data-journal-filter="">Všetky</button>
                  {journalOptions.map((journal) => (
                    <button type="button" role="menuitemradio" aria-checked="false" data-journal-filter={journal.id}>
                      {journal.label}
                    </button>
                  ))}
                </div>
              </details>
            </div>

            <label class="bibliography-control flex items-center justify-center gap-2 border border-belly-gray px-2 py-1.5 text-xs text-belly-dimgray-blue">
              <input id="filter-maps-only" type="checkbox" class="accent-belly-firebrick" />
              Iba mapy/plány
            </label>

            <label class="bibliography-control flex items-center justify-center gap-2 border border-belly-gray px-2 py-1.5 text-xs text-belly-dimgray-blue">
              <input id="filter-fulltext" type="checkbox" class="accent-belly-firebrick" />
              Hľadať vo fulltexte
            </label>
          </div>

          <div id="filter-status" class="hidden border border-belly-lightslategray bg-belly-darkgray px-2 py-1 text-xs font-mono text-belly-firebrick">
            <span id="filter-status-text">Filtre aktívne</span>
            <button id="clear-all-filters" class="float-right font-bold underline">Zrušiť</button>
          </div>

          <div class="bibliography-selection-tools border border-belly-darkgray p-2" aria-label="Zdieľanie a export aktuálneho výberu">
            <div class="bibliography-selection-summary">
              <span>Výber</span>
              <strong id="selection-result-count">{totalArticles}</strong>
              <span id="selection-filter-summary">všetky články</span>
            </div>
            <div class="bibliography-selection-actions">
              <span class="bibliography-share-label">Zdieľať:</span>
              <button id="share-copy-link" class="bibliography-action-link bibliography-share-icon-button" type="button" aria-label="Kopírovať share link" title="Kopírovať link">
                <svg class="bibliography-share-icon bibliography-share-icon-link" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M9.5 14.5l5-5" />
                  <path d="M8.2 10.6l-1.1 1.1a3.6 3.6 0 0 0 5.1 5.1l1.1-1.1" />
                  <path d="M15.8 13.4l1.1-1.1a3.6 3.6 0 0 0-5.1-5.1l-1.1 1.1" />
                </svg>
                <span class="sr-only">Kopírovať link</span>
              </button>
              <a id="share-email-link" class="bibliography-action-link bibliography-share-icon-button" href="#" aria-label="Zdieľať emailom" title="Email">
                <svg class="bibliography-share-icon bibliography-share-icon-email" viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="3" />
                  <path d="M5.2 7.4 12 12.4l6.8-5" />
                  <path d="M5.6 17 10 12.9" />
                  <path d="M18.4 17 14 12.9" />
                </svg>
                <span class="sr-only">Email</span>
              </a>
              <a id="share-facebook-link" class="bibliography-action-link bibliography-share-icon-button" href="#" target="_blank" rel="noreferrer" aria-label="Zdieľať na Facebooku" title="Facebook">
                <svg class="bibliography-share-icon bibliography-share-icon-facebook" viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="12" cy="12" r="11" />
                  <path d="M13.42 18.75v-5.8h1.95l.29-2.25h-2.24V9.26c0-.65.18-1.1 1.12-1.1h1.2V6.14A16 16 0 0 0 13.99 6c-1.73 0-2.92 1.06-2.92 3v1.7H9.1v2.25h1.97v5.8h2.35z" />
                </svg>
                <span class="sr-only">Facebook</span>
              </a>
              <button class="bibliography-action-link" type="button" data-filter-export="html">HTML</button>
              <button class="bibliography-action-link" type="button" data-filter-export="md">MD</button>
              <button class="bibliography-action-link" type="button" data-filter-export="sql">SQL</button>
            </div>
          </div>
        </div>

        <div id="article-list" class="bibliography-results min-h-0 flex-1 overflow-y-auto">
          <div class="p-8 text-center text-xs font-mono text-belly-dimgray">Načítavam bibliografiu...</div>
        </div>

        <div class="bibliography-pager flex items-center justify-between border-t border-belly-darkgray p-3 text-xs font-mono">
          <button id="prev-page-btn" class="bibliography-button-secondary border border-belly-gray px-3 py-1 disabled:opacity-30">Späť</button>
          <span id="page-indicator" class="text-belly-dimgray">Strana 1</span>
          <button id="next-page-btn" class="bibliography-button-secondary border border-belly-gray px-3 py-1 disabled:opacity-30">Ďalej</button>
        </div>
      </section>

      <section id="detail-section" class="bibliography-pane bibliography-detail-section flex min-h-0 flex-col">
        <nav class="bibliography-tabs z-20 flex gap-1 border-b border-belly-darkgray p-2 shadow-sm">
          <button id="tab-detail-btn" class="bg-belly-firebrick px-3 py-1.5 text-xs font-bold text-belly-gainsboro">Detail článku</button>
          <button id="tab-analytics-btn" class="px-3 py-1.5 text-xs font-bold text-belly-dimgray-blue hover:bg-belly-darkgray">Štatistika</button>
        </nav>

        <div class="relative min-h-0 flex-1">
          <div id="detail-panel" class="bibliography-detail-panel absolute inset-0 grid grid-cols-[56%_44%]">
            <article class="bibliography-detail-main min-h-0 overflow-y-auto p-5">
              <div id="no-selection" class="flex h-full items-center justify-center text-center text-sm text-belly-dimgray">
                Vyberte článok zo zoznamu.
              </div>

              <div id="selected-detail" class="bibliography-selected-detail hidden space-y-5">
                <div class="border-b border-belly-darkgray pb-3">
                  <a id="detail-page-link" href="#" class="bibliography-link-button bibliography-link-button-primary mb-3">
                    Permanentná stránka článku <span aria-hidden="true">&rarr;</span>
                  </a>
                  <a id="detail-error-link" href="/nahlasit-chybu/" class="bibliography-link-button mb-3">
                    Našiel som chybu
                  </a>
                  <h2 id="detail-title" class="bibliography-detail-title mt-2 font-display text-xl font-extrabold leading-tight text-belly-black"></h2>
                  <p id="detail-authors" class="bibliography-detail-authors mt-2 border-l-4 border-belly-peru pl-3 text-sm font-semibold text-belly-firebrick"></p>
                </div>

                <dl class="bibliography-meta-grid grid grid-cols-4 gap-2 border border-belly-darkgray p-3 text-xs font-mono">
                  <div><dt class="text-belly-lightslategray">Ročník</dt><dd id="detail-volume" class="font-bold"></dd></div>
                  <div><dt class="text-belly-lightslategray">Číslo</dt><dd id="detail-issue" class="font-bold"></dd></div>
                  <div><dt class="text-belly-lightslategray">Rok</dt><dd id="detail-year" class="font-bold"></dd></div>
                  <div><dt class="text-belly-lightslategray">Strany</dt><dd id="detail-pages" class="font-bold"></dd></div>
                </dl>

                <section>
                  <h3 class="mb-2 text-xs font-bold uppercase tracking-wider text-belly-firebrick">Anotácia</h3>
                  <p id="detail-abstract" class="bibliography-abstract border border-belly-darkgray p-3 text-sm leading-relaxed text-belly-dimgray-blue"></p>
                </section>

                <section>
                  <h3 class="mb-2 text-xs font-bold uppercase tracking-wider text-belly-firebrick">Taxonómie a prepojenia</h3>
                  <div id="detail-tags" class="flex flex-wrap gap-2"></div>
                </section>

                <section class="space-y-3 border-t border-belly-darkgray pt-4">
                  <h3 class="bibliography-section-title text-xs font-bold uppercase tracking-wider text-belly-firebrick">Citácie</h3>
                  <div class="space-y-2 text-xs">
                    <div class="bibliography-citation-box border border-belly-darkgray p-3">
                      <div class="mb-1 flex justify-between gap-3 font-mono text-[10px] uppercase text-belly-lightslategray"><span>ISO 690</span><button class="copy-citation bibliography-action-link text-belly-firebrick" data-target="cite-iso">Kopírovať</button></div>
                      <p id="cite-iso" class="select-all leading-relaxed"></p>
                    </div>
                    <div class="bibliography-citation-box border border-belly-darkgray p-3">
                      <div class="mb-1 flex justify-between gap-3 font-mono text-[10px] uppercase text-belly-lightslategray"><span>APA</span><button class="copy-citation bibliography-action-link text-belly-firebrick" data-target="cite-apa">Kopírovať</button></div>
                      <p id="cite-apa" class="select-all leading-relaxed"></p>
                    </div>
                    <div class="bibliography-citation-box border border-belly-darkgray p-3">
                      <div class="mb-1 flex justify-between gap-3 font-mono text-[10px] uppercase text-belly-lightslategray"><span>MLA</span><button class="copy-citation bibliography-action-link text-belly-firebrick" data-target="cite-mla">Kopírovať</button></div>
                      <p id="cite-mla" class="select-all leading-relaxed"></p>
                    </div>
                  </div>
                </section>

                <section class="space-y-3 border-t border-belly-darkgray pt-4">
                  <div class="flex items-center justify-between">
                    <h3 class="text-xs font-bold uppercase tracking-wider text-belly-firebrick">Komunitné errata</h3>
                    <button id="export-errata-btn" class="bibliography-action-link text-belly-firebrick">Export JSON</button>
                  </div>
                  <div id="errata-list" class="max-h-40 space-y-2 overflow-y-auto text-xs"></div>
                  <form id="errata-form" class="bibliography-soft-box space-y-2 border border-belly-darkgray p-3">
                    <textarea id="errata-text" rows="2" class="w-full resize-y rounded border border-belly-darkgray bg-belly-gainsboro p-2 text-xs outline-none focus:border-belly-firebrick" placeholder="Doplňte opravu, chýbajúci údaj alebo spresnenie..." required></textarea>
                    <button class="bg-belly-firebrick px-3 py-1 text-xs font-bold text-belly-gainsboro" type="submit">Pridať erratum</button>
                  </form>
                </section>
              </div>
            </article>

            <aside class="min-h-0 border-l border-belly-darkgray p-5">
              <div class="bibliography-document-box border border-belly-darkgray p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-wider text-belly-firebrick">Originálny dokument</p>
                <h3 id="pdf-label" class="mt-2 font-display text-lg font-bold text-belly-firebrick">PDF dokument</h3>
                <p id="pdf-helper" class="mt-3 text-sm leading-relaxed text-belly-dimgray-warm">
                  PDF sa v archíve automaticky nenačítava. Otvorí sa až po kliknutí v novej karte prehliadača.
                </p>
                <a id="pdf-open-link" href="#" target="_blank" rel="noreferrer" class="bibliography-button-primary pointer-events-none mt-5 inline-flex w-full items-center justify-center px-4 py-3 text-sm font-bold opacity-40">
                  Otvoriť PDF v novej karte
                </a>
                <figure id="pdf-cover-box" class="bibliography-cover-box mt-5 hidden">
                  <a id="pdf-cover-link" href="#" target="_blank" rel="noreferrer" class="bibliography-cover-link" aria-label="Otvoriť PDF dokument">
                    <img id="pdf-cover-image" alt="" width="280" height="411" loading="lazy" decoding="async" />
                  </a>
                  <figcaption id="pdf-cover-caption" class="mt-2 text-center text-[11px] font-mono uppercase text-belly-lightslategray">
                    Obálka čísla
                  </figcaption>
                </figure>
                <div id="pdf-missing" class="mt-4 hidden border border-belly-peru bg-belly-gainsboro p-3 text-sm text-belly-black-brown">PDF dokument nie je dostupný.</div>
                <div class="mt-5 border-t border-belly-darkgray pt-4 text-xs leading-relaxed text-belly-dimgray">
                  Odkaz smeruje priamo na fyzickú stranu článku, ak je v databáze dostupný offset PDF strany.
                </div>
              </div>
            </aside>
          </div>

          <div id="analytics-panel" class="pointer-events-none absolute inset-0 overflow-y-auto p-6 opacity-0">
            <div class="mx-auto max-w-5xl space-y-6">
              <div class="bibliography-soft-box border border-belly-darkgray p-5 shadow-sm">
                <h2 class="font-display text-lg font-bold text-belly-black">Štatistika archívu</h2>
                <p class="mt-1 text-sm text-belly-dimgray">Grafy sa prepočítavajú podľa aktuálnych filtrov.</p>
              </div>
              <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
                <div class="bibliography-soft-box border border-belly-darkgray p-5 shadow-sm">
                  <h3 class="mb-3 text-xs font-bold uppercase tracking-wider text-belly-firebrick">Publikačná aktivita</h3>
                  <div id="timeline-chart" class="h-[300px] border border-belly-darkgray bg-belly-gainsboro"></div>
                </div>
                <div class="bibliography-soft-box border border-belly-darkgray p-5 shadow-sm">
                  <h3 class="mb-3 text-xs font-bold uppercase tracking-wider text-belly-firebrick">Najaktívnejší autori</h3>
                  <div id="authors-chart" class="h-[300px] border border-belly-darkgray bg-belly-gainsboro"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script>
    import MiniSearch from 'minisearch';

    const ARTICLES_DATA_URL = '/data/articles.json';
    const DEFAULT_PDF_PAGE_LINK_OFFSET = 2;
    const DEFAULT_JOURNAL_ID = 'spravodaj_sss';
    const DEFAULT_JOURNAL_TITLE = 'Spravodaj Slovenskej speleologickej spoločnosti';
    const DEFAULT_JOURNAL_SHORT_TITLE = 'Spravodaj SSS';
    const FULLTEXT_MOBILE_BATCH_SHARDS = 6;

    function isGenericImportAbstract(value) {
      return /Obsahový\s+záznam\s+z\s+čísla\b.*\bimportovaný\s+z\s+obsahu\s+čísla\b/i.test(String(value || '').replace(/\s+/g, ' ').trim());
    }

    function displayAbstract(article) {
      const abstract = String(article.abstract || '').trim();
      return isGenericImportAbstract(abstract) ? '' : abstract;
    }

    function normalizeSearchText(value) {
      return String(value || '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLocaleLowerCase('sk')
        .trim();
    }

    function processSearchTerm(term) {
      return normalizeSearchText(term) || null;
    }

    async function loadArticlesData() {
      const response = await fetch(ARTICLES_DATA_URL);
      if (!response.ok) throw new Error(`Articles data HTTP ${response.status}`);
      return response.json();
    }

    const articlesRaw = await loadArticlesData();
    const articles = articlesRaw.map((article) => ({ ...article, abstract: displayAbstract(article), year_str: String(article.year) }));
    const articlesById = new Map(articles.map((article) => [article.id, article]));
    const articleYears = articles.map((article) => article.year);
    const START_YEAR = Math.min(...articleYears);
    const END_YEAR = Math.max(...articleYears, new Date().getFullYear());
    const miniSearch = new MiniSearch({
      fields: ['title', 'authors', 'abstract', 'year_str', 'volume', 'issue', 'tags', 'caves', 'groups'],
      storeFields: ['id'],
      processTerm: processSearchTerm,
      searchOptions: {
        boost: { title: 4, caves: 3, authors: 2, tags: 2, groups: 2, abstract: 1 },
        prefix: true,
        fuzzy: 0.1
      }
    });
    miniSearch.addAll(articles);

    const state = {
      search: '',
      yearMin: START_YEAR,
      yearMax: END_YEAR,
      journal: '',
      mapsOnly: false,
      fulltext: false,
      page: 1,
      pageSize: 12,
      selectedId: null,
      activeTab: 'detail',
      errata: {}
    };

    const byId = (id) => document.getElementById(id);
    const listEl = byId('article-list');
    const searchInput = byId('search-input');
    const mobileSearchInput = byId('mobile-search-input');
    const mobileSearchOverlay = byId('mobile-search-overlay');
    const mobileSearchToggle = byId('mobile-search-toggle');
    const mobileSearchClose = byId('mobile-search-close');
    const mobileMenuToggle = byId('mobile-menu-toggle');
    const mobileMenuPanel = byId('mobile-menu-panel');
    const yearRangeControl = byId('year-range-control');
    const yearMinInput = byId('year-min');
    const yearMaxInput = byId('year-max');
    const yearLabel = byId('year-range-label');
    const journalFilterMenu = byId('journal-filter-menu');
    const journalFilterCurrent = byId('journal-filter-current');
    const journalFilterOptions = Array.from(document.querySelectorAll('[data-journal-filter]'));
    const filterMapsOnly = byId('filter-maps-only');
    const filterFulltext = byId('filter-fulltext');
    const filterStatus = byId('filter-status');
    const filterStatusText = byId('filter-status-text');
    const selectionResultCount = byId('selection-result-count');
    const selectionFilterSummary = byId('selection-filter-summary');
    const shareCopyLink = byId('share-copy-link');
    const shareEmailLink = byId('share-email-link');
    const shareFacebookLink = byId('share-facebook-link');
    const pageIndicator = byId('page-indicator');
    const prevPageBtn = byId('prev-page-btn');
    const nextPageBtn = byId('next-page-btn');
    let filtered = articles;
    let fulltextMiniSearch = null;
    let fulltextManifest = null;
    let fulltextManifestPromise = null;
    let fulltextLoadPromise = null;
    let fulltextLoadState = 'idle';
    let fulltextStats = null;
    let fulltextBatchProgress = null;
    let d3LoadPromise = null;
    const fulltextLoadedShards = new Set();
    const fulltextLoadingShards = new Map();
    const fulltextLoadedArticleIds = new Set();
    let setupComplete = false;

    function hasMap(article) {
      if (article.has_map_plan === true) return true;
      return (article.map_plan_pages || []).length > 0;
    }

    function firstArticlePage(article) {
      const match = String(article.pages || '').match(/^(\d+)/);
      return match ? Number(match[1]) : 1;
    }

    function pdfPage(article) {
      const printedPage = Number(article.pdf_page_start || firstArticlePage(article) || 1);
      const offset = Number.isFinite(Number(article.pdf_page_offset))
        ? Number(article.pdf_page_offset)
        : DEFAULT_PDF_PAGE_LINK_OFFSET;
      return printedPage + offset;
    }

    function articlePdfUrl(article) {
      return article.pdf_url ? `${article.pdf_url}#page=${pdfPage(article)}` : '';
    }

    function pdfBaseUrl(article) {
      return String(article.pdf_url || '').split('#')[0].split('?')[0];
    }

    function localCoverUiUrl(coverUrl) {
      return String(coverUrl || '').startsWith('/covers/')
        ? String(coverUrl).replace('/covers/', '/covers-ui/')
        : '';
    }

    function pdfCoverCandidates(article) {
      const localCover = String(article.cover_url || '').trim();
      const localCoverUi = localCoverUiUrl(localCover);
      const baseUrl = pdfBaseUrl(article);
      if (!baseUrl || !/\.pdf$/i.test(baseUrl)) return [localCoverUi, localCover].filter(Boolean);
      const withoutExtension = baseUrl.replace(/\.pdf$/i, '');
      return [
        ...(localCoverUi ? [localCoverUi] : []),
        ...(localCover ? [localCover] : []),
        `${withoutExtension}-thumb.png`,
        `${withoutExtension}-thumb.jpg`,
        `${withoutExtension}.png`,
        `${withoutExtension}.jpg`
      ];
    }

    function articleJournalId(article) {
      return article.journal_id || DEFAULT_JOURNAL_ID;
    }

    function articleJournalLabel(article) {
      return article.journal_short_title || article.journal_title || DEFAULT_JOURNAL_SHORT_TITLE;
    }

    function articleJournalTitle(article) {
      return article.journal_title || articleJournalLabel(article);
    }

    function publicDataUrl(fileName) {
      const pathname = window.location.pathname.endsWith('/') ? window.location.pathname : `${window.location.pathname}/`;
      return `${pathname}data/${fileName}`;
    }

    function ensureFulltextMiniSearch() {
      if (fulltextMiniSearch) return fulltextMiniSearch;
      fulltextMiniSearch = new MiniSearch({
        fields: ['t'],
        storeFields: ['a'],
        processTerm: processSearchTerm,
        searchOptions: {
          prefix: true,
          fuzzy: 0.1
        }
      });
      return fulltextMiniSearch;
    }

    function loadFulltextManifest() {
      if (fulltextManifest) return Promise.resolve(fulltextManifest);
      if (fulltextManifestPromise) return fulltextManifestPromise;
      fulltextManifestPromise = fetch(publicDataUrl('fulltext_manifest.json'))
        .then((response) => {
          if (!response.ok) throw new Error(`Fulltext manifest HTTP ${response.status}`);
          return response.json();
        })
        .then((manifest) => {
          fulltextManifest = manifest;
          fulltextStats = {
            chunks: 0,
            articles: 0,
            totalChunks: manifest.chunks || 0,
            totalArticles: manifest.articles || 0
          };
          return manifest;
        });
      return fulltextManifestPromise;
    }

    function fulltextRelevantShards(manifest = fulltextManifest) {
      if (!manifest?.shards?.length) return [];
      return manifest.shards.filter((shard) => {
        if (state.journal && shard.journal_id !== state.journal) return false;
        const year = Number(shard.year);
        if (Number.isFinite(year) && (year < state.yearMin || year > state.yearMax)) return false;
        return true;
      });
    }

    function fulltextMissingRelevantShards() {
      return fulltextRelevantShards().filter((shard) => !fulltextLoadedShards.has(shard.path));
    }

    function loadFulltextShard(shard) {
      if (fulltextLoadedShards.has(shard.path)) return Promise.resolve();
      if (fulltextLoadingShards.has(shard.path)) return fulltextLoadingShards.get(shard.path);
      const promise = fetch(publicDataUrl(shard.path))
        .then((response) => {
          if (!response.ok) throw new Error(`Fulltext shard HTTP ${response.status}: ${shard.path}`);
          return response.json();
        })
        .then((records) => {
          const index = ensureFulltextMiniSearch();
          index.addAll(records);
          records.forEach((record) => fulltextLoadedArticleIds.add(record.a));
          fulltextLoadedShards.add(shard.path);
          fulltextStats = {
            chunks: (fulltextStats?.chunks || 0) + records.length,
            articles: fulltextLoadedArticleIds.size,
            totalChunks: fulltextManifest?.chunks || 0,
            totalArticles: fulltextManifest?.articles || 0
          };
        })
        .finally(() => {
          fulltextLoadingShards.delete(shard.path);
        });
      fulltextLoadingShards.set(shard.path, promise);
      return promise;
    }

    async function loadFulltextShardsInMobileBatches(shards) {
      fulltextLoadState = 'batching';
      fulltextBatchProgress = {
        loaded: 0,
        total: shards.length
      };

      for (let index = 0; index < shards.length; index += FULLTEXT_MOBILE_BATCH_SHARDS) {
        const batch = shards.slice(index, index + FULLTEXT_MOBILE_BATCH_SHARDS);
        await Promise.all(batch.map(loadFulltextShard));
        fulltextBatchProgress.loaded = Math.min(index + batch.length, shards.length);
        applyFilters();
        await new Promise((resolve) => window.setTimeout(resolve, 0));
      }
    }

    function loadFulltextIndex() {
      ensureFulltextMiniSearch();
      if (fulltextLoadPromise) return fulltextLoadPromise;

      fulltextLoadState = 'loading';
      fulltextLoadPromise = loadFulltextManifest()
        .then((manifest) => {
          const relevantShards = fulltextRelevantShards(manifest);
          const missingShards = relevantShards.filter((shard) => !fulltextLoadedShards.has(shard.path));
          if (isMobileViewport() && missingShards.length > FULLTEXT_MOBILE_BATCH_SHARDS) {
            return loadFulltextShardsInMobileBatches(missingShards);
          }
          return Promise.all(missingShards.map(loadFulltextShard));
        })
        .then(() => {
          fulltextLoadState = 'ready';
          fulltextBatchProgress = null;
          applyFilters();
          return fulltextMiniSearch;
        })
        .catch((error) => {
          console.error('Fulltext index sa nepodarilo načítať.', error);
          fulltextLoadState = 'error';
          applyFilters();
          return null;
        })
        .finally(() => {
          fulltextLoadPromise = null;
        });

      applyFilters();
      return fulltextLoadPromise;
    }

    function fulltextStatusLabel(query) {
      if (!state.fulltext) return '';
      if (!query) return 'fulltext pripravený po zadaní hľadania';
      if (fulltextLoadState === 'batching' && fulltextBatchProgress) {
        return `fulltext sa načítava po dávkach: ${fulltextBatchProgress.loaded}/${fulltextBatchProgress.total} indexov`;
      }
      if (fulltextLoadState === 'loading') return 'fulltext sa načítava';
      if (fulltextLoadState === 'error') return 'fulltext index nie je dostupný';
      if (fulltextLoadState === 'ready' && fulltextStats) {
        const total = fulltextStats.totalArticles ? `/${fulltextStats.totalArticles}` : '';
        return `fulltext: ${fulltextStats.articles}${total} článkov`;
      }
      return 'fulltext zapnutý';
    }

    function setTab(tab) {
      state.activeTab = tab;
      const panels = {
        detail: byId('detail-panel'),
        analytics: byId('analytics-panel')
      };
      const buttons = {
        detail: byId('tab-detail-btn'),
        analytics: byId('tab-analytics-btn')
      };
      Object.entries(panels).forEach(([key, panel]) => {
        panel.classList.toggle('opacity-0', key !== tab);
        panel.classList.toggle('pointer-events-none', key !== tab);
      });
      Object.entries(buttons).forEach(([key, button]) => {
        button.className = key === tab
          ? 'bg-belly-firebrick px-3 py-1.5 text-xs font-bold text-belly-gainsboro'
          : 'px-3 py-1.5 text-xs font-bold text-belly-dimgray-blue hover:bg-belly-darkgray';
      });
      if (tab === 'analytics') renderCharts();
    }

    function isMobileViewport() {
      return window.matchMedia('(max-width: 1023px)').matches;
    }

    function scrollDetailIntoView() {
      if (!isMobileViewport() || !setupComplete) return;
      byId('detail-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function syncSearchFields(value) {
      searchInput.value = value;
      mobileSearchInput.value = value;
    }

    function syncYearRangeControl() {
      const span = Math.max(1, END_YEAR - START_YEAR);
      const startPercent = ((state.yearMin - START_YEAR) / span) * 100;
      const endPercent = ((state.yearMax - START_YEAR) / span) * 100;
      yearMinInput.value = String(state.yearMin);
      yearMaxInput.value = String(state.yearMax);
      yearLabel.textContent = `${state.yearMin} - ${state.yearMax}`;
      yearRangeControl.style.setProperty('--range-start', `${Math.max(0, Math.min(100, startPercent))}%`);
      yearRangeControl.style.setProperty('--range-end', `${Math.max(0, Math.min(100, endPercent))}%`);
    }

    function clampYear(value, fallback) {
      if (value === null || value === undefined || String(value).trim() === '') return fallback;
      const year = Number(value);
      if (!Number.isFinite(year)) return fallback;
      return Math.max(START_YEAR, Math.min(END_YEAR, Math.round(year)));
    }

    function parseBooleanParam(value) {
      return ['1', 'true', 'yes', 'ano'].includes(String(value || '').toLocaleLowerCase('sk'));
    }

    function hydrateStateFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const query = params.get('q') || params.get('search') || '';
      const journal = params.get('journal') || '';
      const yearRange = params.get('year') || '';
      const yearMatch = yearRange.match(/^(\d{4})-(\d{4})$/);
      const rawYearMin = yearMatch ? yearMatch[1] : params.get('year_min');
      const rawYearMax = yearMatch ? yearMatch[2] : params.get('year_max');

      state.search = query.trim();
      state.journal = journal;
      state.yearMin = clampYear(rawYearMin, START_YEAR);
      state.yearMax = clampYear(rawYearMax, END_YEAR);
      if (state.yearMin > state.yearMax) {
        [state.yearMin, state.yearMax] = [state.yearMax, state.yearMin];
      }
      state.mapsOnly = parseBooleanParam(params.get('maps'));
      state.fulltext = parseBooleanParam(params.get('fulltext'));
      state.page = 1;
    }

    function syncFilterControls() {
      syncSearchFields(state.search);
      syncYearRangeControl();
      syncJournalFilterControl();
      filterMapsOnly.checked = state.mapsOnly;
      filterFulltext.checked = state.fulltext;
    }

    function journalLabelForValue(value) {
      if (!value) return 'Všetky';
      const journalArticle = articles.find((article) => articleJournalId(article) === value);
      return journalArticle ? articleJournalLabel(journalArticle) : value;
    }

    function syncJournalFilterControl() {
      journalFilterCurrent.textContent = journalLabelForValue(state.journal);
      journalFilterOptions.forEach((button) => {
        const active = button.dataset.journalFilter === state.journal;
        button.setAttribute('aria-checked', active ? 'true' : 'false');
        button.classList.toggle('is-active', active);
      });
    }

    function currentFilterParts() {
      const parts = [];
      if (state.search.trim()) parts.push(`hľadanie: ${state.search.trim()}`);
      if (state.journal) {
        const journalArticle = articles.find((article) => articleJournalId(article) === state.journal);
        parts.push(`časopis: ${journalArticle ? articleJournalLabel(journalArticle) : state.journal}`);
      }
      if (state.yearMin > START_YEAR || state.yearMax < END_YEAR) parts.push(`roky: ${state.yearMin}-${state.yearMax}`);
      if (state.mapsOnly) parts.push('iba mapy/plány');
      if (state.fulltext) parts.push('vrátane fulltextu');
      return parts;
    }

    function buildCurrentFilterUrl() {
      const url = new URL(window.location.href);
      url.search = '';
      const query = state.search.trim();
      if (query) url.searchParams.set('q', query);
      if (state.journal) url.searchParams.set('journal', state.journal);
      if (state.yearMin > START_YEAR || state.yearMax < END_YEAR) url.searchParams.set('year', `${state.yearMin}-${state.yearMax}`);
      if (state.mapsOnly) url.searchParams.set('maps', '1');
      if (state.fulltext) url.searchParams.set('fulltext', '1');
      return url;
    }

    function syncShareAndExportControls() {
      const url = buildCurrentFilterUrl();
      const parts = currentFilterParts();
      const filterText = parts.length ? parts.join(' · ') : 'všetky články';
      const title = 'Digitálna bibliografia SSS - filtrovaný výber';
      const body = `${title}\n${filterText}\n${filtered.length} výsledkov\n${url.toString()}`;

      selectionResultCount.textContent = `${filtered.length} výsledkov`;
      selectionFilterSummary.textContent = filterText;
      shareEmailLink.href = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(body)}`;
      shareFacebookLink.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url.toString())}`;
    }

    async function copyText(value) {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(value);
        return;
      }
      const textarea = document.createElement('textarea');
      textarea.value = value;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.left = '-9999px';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
    }

    function temporarilyConfirmButton(button) {
      button.classList.add('is-confirmed');
      window.setTimeout(() => {
        button.classList.remove('is-confirmed');
      }, 1600);
    }

    function setSearchValue(value) {
      state.search = value;
      state.page = 1;
      syncSearchFields(value);
      applyFilters();
    }

    function closeMobileMenu() {
      mobileMenuPanel.classList.remove('is-open');
      mobileMenuPanel.hidden = true;
      mobileMenuToggle.setAttribute('aria-expanded', 'false');
    }

    function toggleMobileMenu() {
      const willOpen = mobileMenuPanel.hidden;
      if (willOpen) {
        mobileMenuPanel.hidden = false;
        mobileMenuPanel.classList.add('is-open');
        mobileMenuToggle.setAttribute('aria-expanded', 'true');
        return;
      }
      closeMobileMenu();
    }

    function openMobileSearch() {
      closeMobileMenu();
      mobileSearchOverlay.hidden = false;
      mobileSearchOverlay.classList.add('is-open');
      mobileSearchOverlay.setAttribute('aria-hidden', 'false');
      mobileSearchInput.value = state.search;
      window.requestAnimationFrame(() => {
        mobileSearchInput.focus();
        mobileSearchInput.select();
      });
    }

    function closeMobileSearch() {
      mobileSearchOverlay.classList.remove('is-open');
      mobileSearchOverlay.setAttribute('aria-hidden', 'true');
      mobileSearchOverlay.hidden = true;
      mobileSearchToggle.focus();
    }

    function applyFilters() {
      const query = state.search.trim();
      const base = query
        ? miniSearch.search(query).map((hit) => articlesById.get(Number(hit.id))).filter(Boolean)
        : articles.slice();

      if (query && state.fulltext) {
        if (fulltextMiniSearch) {
          const seen = new Set(base.map((article) => article.id));
          fulltextMiniSearch.search(query).forEach((hit) => {
            const article = articlesById.get(hit.a);
            if (article && !seen.has(article.id)) {
              base.push(article);
              seen.add(article.id);
            }
          });
        }
        if (!fulltextManifest || fulltextMissingRelevantShards().length) {
          loadFulltextIndex();
        }
      }

      filtered = base.filter((article) => {
        if (article.year < state.yearMin || article.year > state.yearMax) return false;
        if (state.journal && articleJournalId(article) !== state.journal) return false;
        if (state.mapsOnly && !hasMap(article)) return false;
        return true;
      }).sort((a, b) => {
        const mapDelta = Number(hasMap(b)) - Number(hasMap(a));
        return mapDelta || b.year - a.year || b.id - a.id;
      });

      const selectedStillVisible = filtered.some((article) => article.id === state.selectedId);
      state.page = Math.min(state.page, Math.max(1, Math.ceil(filtered.length / state.pageSize)));
      const active = query || state.yearMin > START_YEAR || state.yearMax < END_YEAR || state.journal || state.mapsOnly || state.fulltext;
      filterStatus.classList.toggle('hidden', !active);
      filterStatusText.textContent = [`${filtered.length} výsledkov`, fulltextStatusLabel(query)].filter(Boolean).join(' · ');
      byId('stat-total').textContent = String(filtered.length);
      byId('stat-maps').textContent = String(filtered.filter(hasMap).length);
      syncShareAndExportControls();
      renderList();
      if (!selectedStillVisible) {
        if (filtered.length) selectArticle(filtered[0].id);
        else clearSelectedArticle();
      }
      if (state.activeTab === 'analytics') renderCharts();
    }

    function renderList() {
      const totalPages = Math.max(1, Math.ceil(filtered.length / state.pageSize));
      state.page = Math.min(state.page, totalPages);
      const start = (state.page - 1) * state.pageSize;
      const pageItems = filtered.slice(start, start + state.pageSize);
      listEl.replaceChildren();

      if (pageItems.length === 0) {
        appendTextElement(listEl, 'div', 'p-8 text-center text-sm text-belly-lightslategray', 'Nenašli sa žiadne články.');
      }

      pageItems.forEach((article) => {
        const abstract = displayAbstract(article);
        const row = document.createElement('button');
        row.type = 'button';
        row.className = `article-result-card ${state.selectedId === article.id ? 'is-selected' : ''}`;

        const meta = document.createElement('div');
        meta.className = 'article-result-meta';
        appendTextElement(meta, 'span', '', articleJournalLabel(article));
        appendTextElement(meta, 'span', 'separator', '/');
        appendTextElement(meta, 'span', '', article.year);
        appendTextElement(meta, 'span', 'separator', '/');
        appendTextElement(meta, 'span', '', `č. ${article.issue || '-'}`);
        appendTextElement(meta, 'span', 'separator', '/');
        appendTextElement(meta, 'span', '', `s. ${article.pages || '-'}`);
        if (hasMap(article)) {
          appendTextElement(meta, 'span', 'article-result-badge ml-auto', 'mapa/plán');
        }
        row.appendChild(meta);

        appendTextElement(row, 'h3', 'article-result-title', article.title || 'Bez názvu');
        appendTextElement(row, 'p', 'article-result-author', formatAuthorsDisplay(article.authors || []));
        if (abstract) {
          appendTextElement(row, 'p', 'article-result-abstract line-clamp-2', abstract);
        }
        row.addEventListener('click', () => selectArticle(article.id));
        listEl.appendChild(row);
      });

      pageIndicator.textContent = `Strana ${state.page} z ${totalPages} (${filtered.length})`;
      prevPageBtn.disabled = state.page <= 1;
      nextPageBtn.disabled = state.page >= totalPages;
    }

    function appendTextElement(parent, tagName, className, text) {
      const element = document.createElement(tagName);
      if (className) element.className = className;
      element.textContent = String(text ?? '');
      parent.appendChild(element);
      return element;
    }

    function tagBadge(text, href) {
      const element = document.createElement(href ? 'a' : 'span');
      element.className = 'bibliography-tag rounded-full border border-belly-darkgray px-2.5 py-1 text-[11px] font-mono text-belly-dimgray';
      element.textContent = text;
      if (href) {
        element.href = href;
        element.target = '_blank';
        element.rel = 'noreferrer';
      }
      return element;
    }

    function articleErrorReportUrl(article) {
      return `/clanky/${article.id}/edit/`;
    }

    function clearSelectedArticle() {
      state.selectedId = null;
      byId('no-selection').classList.remove('hidden');
      byId('selected-detail').classList.add('hidden');
      renderList();
    }

    function selectArticle(id) {
      const article = articles.find((item) => item.id === id);
      if (!article) return;
      state.selectedId = id;
      byId('no-selection').classList.add('hidden');
      byId('selected-detail').classList.remove('hidden');

      byId('detail-page-link').href = `/clanky/${article.id}/`;
      byId('detail-error-link').href = articleErrorReportUrl(article);
      byId('detail-title').textContent = article.title;
      byId('detail-authors').textContent = formatAuthorsDisplay(article.authors || []);
      byId('detail-volume').textContent = article.volume || '-';
      byId('detail-issue').textContent = article.issue || '-';
      byId('detail-year').textContent = String(article.year || '-');
      byId('detail-pages').textContent = article.pages || '-';
      byId('detail-abstract').textContent = displayAbstract(article) || 'Anotácia zatiaľ nie je k dispozícii.';

      const tagsEl = byId('detail-tags');
      tagsEl.innerHTML = '';
      (article.wikidata || []).forEach((item) => tagsEl.appendChild(tagBadge(item.name, item.url)));
      (article.caves || []).forEach((item) => tagsEl.appendChild(tagBadge(item)));
      (article.groups || []).forEach((item) => tagsEl.appendChild(tagBadge(item)));
      (article.tags || []).forEach((item) => tagsEl.appendChild(tagBadge(item)));
      if (!tagsEl.children.length) tagsEl.appendChild(tagBadge('Speleológia'));

      generateCitations(article);
      renderErrata(article.id);

      const pdfUrl = articlePdfUrl(article);
      const pdfMissing = byId('pdf-missing');
      const pdfOpenLink = byId('pdf-open-link');
      const pdfCoverBox = byId('pdf-cover-box');
      const pdfCoverImage = byId('pdf-cover-image');
      const pdfCoverLink = byId('pdf-cover-link');
      const pdfCoverCaption = byId('pdf-cover-caption');
      if (pdfUrl) {
        pdfOpenLink.href = pdfUrl;
        pdfOpenLink.classList.remove('pointer-events-none', 'opacity-40');
        byId('pdf-label').textContent = `PDF: ${articleJournalLabel(article)}, ${article.year}, č. ${article.issue}, s. ${article.pages}`;
        pdfMissing.classList.add('hidden');

        const coverCandidates = pdfCoverCandidates(article);
        if (coverCandidates.length) {
          pdfCoverBox.classList.remove('hidden');
          pdfCoverLink.href = article.pdf_url || pdfUrl;
          pdfCoverCaption.textContent = `Obálka ${articleJournalLabel(article)} ${article.year}, č. ${article.issue}`;
          pdfCoverImage.dataset.coverCandidates = coverCandidates.join('|');
          pdfCoverImage.dataset.coverIndex = '0';
          pdfCoverImage.alt = `Obálka ${articleJournalLabel(article)} ${article.year}, číslo ${article.issue}`;
          if (isMobileViewport()) {
            pdfCoverImage.loading = 'lazy';
            pdfCoverImage.fetchPriority = 'low';
          } else {
            pdfCoverImage.loading = 'eager';
            pdfCoverImage.fetchPriority = 'high';
          }
          pdfCoverImage.src = coverCandidates[0];
        } else {
          pdfCoverBox.classList.add('hidden');
          pdfCoverImage.removeAttribute('src');
          pdfCoverImage.dataset.coverCandidates = '';
        }
      } else {
        pdfOpenLink.href = '#';
        pdfOpenLink.classList.add('pointer-events-none', 'opacity-40');
        byId('pdf-label').textContent = 'PDF dokument';
        pdfMissing.classList.remove('hidden');
        pdfCoverBox.classList.add('hidden');
        pdfCoverImage.removeAttribute('src');
        pdfCoverImage.dataset.coverCandidates = '';
      }

      renderList();
      setTab('detail');
      scrollDetailIntoView();
    }

    function formatAuthorsIso(authors) {
      return formatAuthorsDisplay(authors.map((author) => {
        if (!author.includes(',')) return author.toUpperCase();
        const [surname, initials] = author.split(',');
        return `${surname.trim().toUpperCase()}, ${initials.trim()}`;
      }));
    }

    function formatAuthorsDisplay(authors) {
      if (!authors.length) return 'Anonymus';
      if (authors.length === 1) return authors[0];
      if (authors.length === 2) return `${authors[0]} a ${authors[1]}`;
      return `${authors.slice(0, -1).join(', ')} a ${authors[authors.length - 1]}`;
    }

    function formatAuthorsPlain(authors) {
      return formatAuthorsDisplay(authors);
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function markdownEscape(value) {
      return String(value ?? '').replace(/\r?\n/g, ' ').trim();
    }

    function sqlString(value) {
      if (value === null || value === undefined || value === '') return 'NULL';
      return `'${String(value).replace(/'/g, "''")}'`;
    }

    function exportMetadataLines() {
      const parts = currentFilterParts();
      return [
        `Vygenerované: ${new Date().toLocaleString('sk-SK')}`,
        `Výsledkov: ${filtered.length}`,
        `Filtre: ${parts.length ? parts.join(' · ') : 'všetky články'}`,
        `Share link: ${buildCurrentFilterUrl().toString()}`
      ];
    }

    function articleExportRecord(article, index) {
      return {
        order: index + 1,
        id: article.id,
        title: article.title || '',
        authors: formatAuthorsDisplay(article.authors || []),
        journal: articleJournalTitle(article),
        journalShort: articleJournalLabel(article),
        year: article.year || '',
        volume: article.volume || '',
        issue: article.issue || '',
        pages: article.pages || '',
        abstract: displayAbstract(article) || '',
        tags: [...(article.tags || []), ...(article.caves || []), ...(article.groups || [])].join('; '),
        pdfUrl: articlePdfUrl(article)
      };
    }

    function buildFilteredHtmlExport() {
      const metadata = exportMetadataLines();
      const rows = filtered.map(articleExportRecord);
      return `<!doctype html>
<html lang="sk">
<head>
  <meta charset="utf-8">
  <title>Filtrovaný export bibliografie</title>
  <style>
    body { font-family: Inter, system-ui, sans-serif; line-height: 1.5; margin: 2rem; color: #241715; }
    h1 { color: #ce3d3b; }
    article { border-top: 1px solid #ddd; padding: 1rem 0; }
    h2 { font-size: 1.12rem; margin: 0 0 .35rem; }
    .meta, .small { color: #5d5550; font-size: .9rem; }
    .abstract { margin-top: .55rem; }
  </style>
</head>
<body>
  <h1>Filtrovaný export bibliografie</h1>
  <ul>
    ${metadata.map((item) => `<li>${escapeHtml(item)}</li>`).join('\n    ')}
  </ul>
  ${rows.map((item) => `<article id="clanok-${item.id}">
    <h2>${item.order}. ${escapeHtml(item.title)}</h2>
    <div class="meta"><strong>Autor:</strong> ${escapeHtml(item.authors)}</div>
    <div class="meta"><strong>Časopis:</strong> ${escapeHtml(item.journal)} (${escapeHtml(item.year)}), roč. ${escapeHtml(item.volume || '-')}, č. ${escapeHtml(item.issue || '-')}, s. ${escapeHtml(item.pages || '-')}</div>
    ${item.abstract ? `<p class="abstract">${escapeHtml(item.abstract)}</p>` : ''}
    ${item.tags ? `<div class="small"><strong>Taxonómie:</strong> ${escapeHtml(item.tags)}</div>` : ''}
    ${item.pdfUrl ? `<div class="small"><a href="${escapeHtml(item.pdfUrl)}">PDF strana</a></div>` : ''}
    <div class="small">Pôvodné ID článku: ${escapeHtml(item.id)}</div>
  </article>`).join('\n')}
</body>
</html>
`;
    }

    function buildFilteredMarkdownExport() {
      const metadata = exportMetadataLines().map((item) => `- ${item}`).join('\n');
      const rows = filtered.map(articleExportRecord);
      return `# Filtrovaný export bibliografie

${metadata}

${rows.map((item) => `## ${item.order}. ${markdownEscape(item.title)}

- Pôvodné ID článku: ${item.id}
- Autor: ${markdownEscape(item.authors)}
- Časopis: ${markdownEscape(item.journal)}
- Rok: ${item.year}
- Ročník: ${markdownEscape(item.volume || '-')}
- Číslo: ${markdownEscape(item.issue || '-')}
- Strany: ${markdownEscape(item.pages || '-')}
${item.tags ? `- Taxonómie: ${markdownEscape(item.tags)}\n` : ''}${item.pdfUrl ? `- PDF: ${item.pdfUrl}\n` : ''}
${item.abstract ? `${markdownEscape(item.abstract)}\n` : ''}`).join('\n')}
`;
    }

    function buildFilteredSqlExport() {
      const rows = filtered.map(articleExportRecord);
      const header = exportMetadataLines().map((item) => `-- ${item}`).join('\n');
      const values = rows.map((item) => `INSERT INTO bibliography_search_export (
  sort_order, source_article_id, title, authors, journal, journal_short, year, volume, issue, pages, abstract, tags, pdf_url
) VALUES (
  ${item.order}, ${item.id}, ${sqlString(item.title)}, ${sqlString(item.authors)}, ${sqlString(item.journal)}, ${sqlString(item.journalShort)}, ${Number(item.year) || 'NULL'}, ${sqlString(item.volume)}, ${sqlString(item.issue)}, ${sqlString(item.pages)}, ${sqlString(item.abstract)}, ${sqlString(item.tags)}, ${sqlString(item.pdfUrl)}
);`).join('\n\n');
      return `${header}

DROP TABLE IF EXISTS bibliography_search_export;
CREATE TABLE bibliography_search_export (
  sort_order INTEGER NOT NULL,
  source_article_id INTEGER NOT NULL,
  title TEXT NOT NULL,
  authors TEXT,
  journal TEXT,
  journal_short TEXT,
  year INTEGER,
  volume TEXT,
  issue TEXT,
  pages TEXT,
  abstract TEXT,
  tags TEXT,
  pdf_url TEXT
);

${values}
`;
    }

    function exportFileName(extension) {
      const slug = normalizeSearchText(state.search || 'vyber')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '')
        .slice(0, 36) || 'vyber';
      const date = new Date().toISOString().slice(0, 10).replace(/-/g, '');
      return `bibliografia_${slug}_${date}.${extension}`;
    }

    function downloadTextFile(content, fileName, type) {
      const blob = new Blob([content], { type });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = fileName;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    }

    function exportFilteredResults(format) {
      if (format === 'html') {
        downloadTextFile(buildFilteredHtmlExport(), exportFileName('html'), 'text/html;charset=utf-8');
      } else if (format === 'md') {
        downloadTextFile(buildFilteredMarkdownExport(), exportFileName('md'), 'text/markdown;charset=utf-8');
      } else if (format === 'sql') {
        downloadTextFile(buildFilteredSqlExport(), exportFileName('sql'), 'application/sql;charset=utf-8');
      }
    }

    function generateCitations(article) {
      const journal = article.journal_title || 'Spravodaj Slovenskej speleologickej spoločnosti';
      const authors = article.authors || ['Anonymus'];
      byId('cite-iso').textContent = `${formatAuthorsIso(authors)}. ${article.title}. In: ${journal}. ${article.year}, roč. ${article.volume || 'I.'}, č. ${article.issue}, s. ${article.pages}.`;
      byId('cite-apa').textContent = `${formatAuthorsPlain(authors)} (${article.year}). ${article.title}. ${journal}, ${article.volume || 'I.'}(${article.issue}), ${article.pages}.`;
      byId('cite-mla').textContent = `${formatAuthorsPlain(authors)}. "${article.title}." ${journal}, vol. ${article.volume || 'I.'}, no. ${article.issue}, ${article.year}, pp. ${article.pages}.`;
    }

    function loadErrata() {
      try {
        state.errata = JSON.parse(localStorage.getItem('speleo_errata') || '{}');
      } catch {
        state.errata = {};
      }
    }

    function saveErrata() {
      localStorage.setItem('speleo_errata', JSON.stringify(state.errata));
    }

    function renderErrata(articleId) {
      const list = state.errata[articleId] || [];
      const listEl = byId('errata-list');
      listEl.replaceChildren();
      if (!list.length) {
        appendTextElement(listEl, 'p', 'text-belly-lightslategray', 'K tomuto článku zatiaľ nie sú lokálne uložené errata.');
        return;
      }
      list.forEach((item) => {
        const row = document.createElement('div');
        row.className = 'bibliography-soft-box rounded border border-belly-darkgray p-2';
        appendTextElement(row, 'div', 'mb-1 font-mono text-[10px] text-belly-lightslategray', item.date);
        appendTextElement(row, 'p', 'whitespace-pre-line text-belly-dimgray-blue', item.text);
        listEl.appendChild(row);
      });
    }

    function exportErrata() {
      const blob = new Blob([JSON.stringify(state.errata, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = 'komunitne_errata_spravodaj_sss.json';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    }

    function loadD3() {
      if (window.d3) return Promise.resolve(window.d3);
      if (d3LoadPromise) return d3LoadPromise;

      d3LoadPromise = new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = 'https://d3js.org/d3.v7.min.js';
        script.async = true;
        script.onload = () => resolve(window.d3);
        script.onerror = () => reject(new Error('D3 sa nepodarilo načítať.'));
        document.head.appendChild(script);
      });
      return d3LoadPromise;
    }

    function setChartLoadingState() {
      ['timeline-chart', 'authors-chart'].forEach((id) => {
        const container = byId(id);
        if (!container.dataset.loading) {
          container.dataset.loading = 'true';
          container.textContent = 'Grafy sa načítavajú...';
        }
      });
    }

    function clearChartLoadingState() {
      ['timeline-chart', 'authors-chart'].forEach((id) => {
        delete byId(id).dataset.loading;
      });
    }

    function renderCharts() {
      if (window.d3) {
        clearChartLoadingState();
        renderTimeline(window.d3);
        renderAuthors(window.d3);
        return;
      }

      setChartLoadingState();
      loadD3()
        .then((d3) => {
          clearChartLoadingState();
          if (state.activeTab === 'analytics') {
            renderTimeline(d3);
            renderAuthors(d3);
          }
        })
        .catch(() => {
          ['timeline-chart', 'authors-chart'].forEach((id) => {
            byId(id).textContent = 'Grafy sa nepodarilo načítať.';
          });
        });
    }

    function renderTimeline(d3) {
      const container = byId('timeline-chart');
      container.innerHTML = '';
      const width = container.clientWidth || 500;
      const height = container.clientHeight || 300;
      const margin = { top: 18, right: 16, bottom: 34, left: 34 };
      const years = new Map();
      for (let year = START_YEAR; year <= END_YEAR; year++) years.set(year, 0);
      filtered.forEach((article) => years.set(article.year, (years.get(article.year) || 0) + 1));
      const data = Array.from(years.entries()).map(([year, count]) => ({ year, count }));
      const svg = d3.select(container).append('svg').attr('width', '100%').attr('height', '100%').attr('viewBox', `0 0 ${width} ${height}`);
      const x = d3.scaleBand().domain(data.map((item) => item.year)).range([margin.left, width - margin.right]).padding(0.15);
      const y = d3.scaleLinear().domain([0, d3.max(data, (item) => item.count) || 1]).nice().range([height - margin.bottom, margin.top]);
      svg.append('g').attr('transform', `translate(0,${height - margin.bottom})`).call(d3.axisBottom(x).tickValues(x.domain().filter((_, i) => i % 5 === 0))).selectAll('text').attr('font-size', 10);
      svg.append('g').attr('transform', `translate(${margin.left},0)`).call(d3.axisLeft(y).ticks(5)).selectAll('text').attr('font-size', 10);
      svg.selectAll('rect').data(data).enter().append('rect').attr('x', (item) => x(item.year)).attr('y', (item) => y(item.count)).attr('width', x.bandwidth()).attr('height', (item) => y(0) - y(item.count)).attr('fill', 'var(--color-belly-firebrick)').attr('rx', 1);
    }

    function renderAuthors(d3) {
      const container = byId('authors-chart');
      container.innerHTML = '';
      const width = container.clientWidth || 500;
      const height = container.clientHeight || 300;
      const margin = { top: 12, right: 18, bottom: 26, left: 118 };
      const counts = new Map();
      filtered.forEach((article) => (article.authors || []).forEach((author) => {
        if (!['Anonymus', 'Redakcia'].includes(author)) counts.set(author, (counts.get(author) || 0) + 1);
      }));
      const data = Array.from(counts.entries()).map(([author, count]) => ({ author, count })).sort((a, b) => b.count - a.count).slice(0, 12);
      const svg = d3.select(container).append('svg').attr('width', '100%').attr('height', '100%').attr('viewBox', `0 0 ${width} ${height}`);
      const y = d3.scaleBand().domain(data.map((item) => item.author)).range([margin.top, height - margin.bottom]).padding(0.2);
      const x = d3.scaleLinear().domain([0, d3.max(data, (item) => item.count) || 1]).nice().range([margin.left, width - margin.right]);
      svg.append('g').attr('transform', `translate(${margin.left},0)`).call(d3.axisLeft(y)).selectAll('text').attr('font-size', 10);
      svg.append('g').attr('transform', `translate(0,${height - margin.bottom})`).call(d3.axisBottom(x).ticks(5)).selectAll('text').attr('font-size', 10);
      svg.selectAll('rect').data(data).enter().append('rect').attr('x', margin.left).attr('y', (item) => y(item.author)).attr('width', (item) => x(item.count) - margin.left).attr('height', y.bandwidth()).attr('fill', 'var(--color-belly-firebrick)').attr('rx', 2);
    }

    function setup() {
      loadErrata();
      hydrateStateFromUrl();
      syncFilterControls();
      applyFilters();
      if (filtered.length) selectArticle(filtered[0].id);

      searchInput.addEventListener('input', (event) => {
        setSearchValue(event.target.value);
      });
      mobileSearchInput.addEventListener('input', (event) => setSearchValue(event.target.value));
      mobileSearchToggle.addEventListener('click', openMobileSearch);
      mobileSearchClose.addEventListener('click', closeMobileSearch);
      mobileMenuToggle.addEventListener('click', toggleMobileMenu);
      mobileMenuPanel.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeMobileMenu);
      });
      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        if (!mobileSearchOverlay.hidden) closeMobileSearch();
        if (!mobileMenuPanel.hidden) closeMobileMenu();
      });
      yearMinInput.addEventListener('input', (event) => {
        state.yearMin = Math.min(Number(event.target.value), state.yearMax);
        syncYearRangeControl();
        state.page = 1;
        applyFilters();
      });
      yearMaxInput.addEventListener('input', (event) => {
        state.yearMax = Math.max(Number(event.target.value), state.yearMin);
        syncYearRangeControl();
        state.page = 1;
        applyFilters();
      });
      byId('reset-years-btn').addEventListener('click', () => {
        state.yearMin = START_YEAR;
        state.yearMax = END_YEAR;
        syncYearRangeControl();
        state.page = 1;
        applyFilters();
      });
      journalFilterOptions.forEach((button) => {
        button.addEventListener('click', () => {
          state.journal = button.dataset.journalFilter || '';
          state.page = 1;
          syncJournalFilterControl();
          journalFilterMenu.open = false;
          applyFilters();
        });
      });
      filterMapsOnly.addEventListener('change', (event) => {
        state.mapsOnly = event.target.checked;
        state.page = 1;
        applyFilters();
      });
      filterFulltext.addEventListener('change', (event) => {
        state.fulltext = event.target.checked;
        state.page = 1;
        applyFilters();
      });
      byId('clear-all-filters').addEventListener('click', () => {
        state.search = '';
        state.yearMin = START_YEAR;
        state.yearMax = END_YEAR;
        state.journal = '';
        state.mapsOnly = false;
        state.fulltext = false;
        state.page = 1;
        syncSearchFields('');
        syncYearRangeControl();
        syncJournalFilterControl();
        filterMapsOnly.checked = false;
        filterFulltext.checked = false;
        applyFilters();
      });
      shareCopyLink.addEventListener('click', async () => {
        await copyText(buildCurrentFilterUrl().toString());
        temporarilyConfirmButton(shareCopyLink);
      });
      document.querySelectorAll('[data-filter-export]').forEach((button) => {
        button.addEventListener('click', () => exportFilteredResults(button.dataset.filterExport));
      });
      prevPageBtn.addEventListener('click', () => {
        state.page = Math.max(1, state.page - 1);
        renderList();
      });
      nextPageBtn.addEventListener('click', () => {
        state.page += 1;
        renderList();
      });
      byId('tab-detail-btn').addEventListener('click', () => setTab('detail'));
      byId('tab-analytics-btn').addEventListener('click', () => setTab('analytics'));
      byId('pdf-cover-image').addEventListener('error', (event) => {
        const image = event.currentTarget;
        const candidates = (image.dataset.coverCandidates || '').split('|').filter(Boolean);
        const nextIndex = Number(image.dataset.coverIndex || '0') + 1;
        if (nextIndex < candidates.length) {
          image.dataset.coverIndex = String(nextIndex);
          image.src = candidates[nextIndex];
        } else {
          byId('pdf-cover-box').classList.add('hidden');
        }
      });
      document.querySelectorAll('.copy-citation').forEach((button) => {
        button.addEventListener('click', () => {
          const target = byId(button.dataset.target);
          if (target?.textContent) navigator.clipboard.writeText(target.textContent);
        });
      });
      byId('errata-form').addEventListener('submit', (event) => {
        event.preventDefault();
        if (!state.selectedId) return;
        const textarea = byId('errata-text');
        const text = textarea.value.trim();
        if (!text) return;
        const key = String(state.selectedId);
        state.errata[key] = state.errata[key] || [];
        state.errata[key].push({ text, date: new Date().toISOString() });
        textarea.value = '';
        saveErrata();
        renderErrata(key);
      });
      byId('export-errata-btn').addEventListener('click', exportErrata);
      setTab('detail');
      setupComplete = true;
    }

    if (document.readyState === 'loading') {
      window.addEventListener('DOMContentLoaded', setup);
    } else {
      setup();
    }
  </script>
</Layout>
