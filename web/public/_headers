# Cloudflare Pages custom headers.
# Keep this policy conservative: the site currently uses inline Astro scripts,
# Google Fonts, Turnstile and a D3 CDN script.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), ambient-light-sensor=(), autoplay=(), battery=(), camera=(), display-capture=(), document-domain=(), encrypted-media=(), fullscreen=(self), gamepad=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), serial=(), usb=(), web-share=(self), xr-spatial-tracking=()
  Content-Security-Policy: base-uri 'self'; object-src 'none'; frame-ancestors 'self' https://sss.sk https://www.sss.sk

https://bibliografia-spravodaj.pages.dev/*
  X-Robots-Tag: noindex
